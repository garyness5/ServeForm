  "text": "{{\n  inpQuantity.text && inpPurchaseCost.text\n    ? (() => {\n        const v =\n          Number(inpPurchaseCost.text) /\n          (\n            Number(inpQuantity.text) *\n            (1 - (Number(inpWastage.text || 0) / 100))\n          );\n\n        const price = v % 1 === 0 ? v.toFixed(0) : v.toFixed(2);\n        const unit = selPurchaseUnit.selectedOptionLabel || \"\";\n\n        return unit ? `$${price} / ${unit}` : `$${price}`;\n      })()\n    : \"\"\n}}",
